# Cognee Configuration
# Location: ~/.hai/cognee/.env

# Debug mode
DEBUG=false

# Environment
ENVIRONMENT=local
LOG_LEVEL=INFO

# CORS settings (default allows all - restrict in production)
CORS_ALLOWED_ORIGINS=*

# Database configuration (PostgreSQL with pgvector)
DB_PROVIDER=postgresql
DB_HOST=cognee-postgres
DB_PORT=5432
DB_NAME=cognee_db
DB_USERNAME=cognee
DB_PASSWORD=cognee

# Vector store configuration
VECTOR_DB_PROVIDER=pgvector

# LLM Configuration (using local llamacpp)
LLM_API_BASE=http://host.docker.internal:3420/v1
LLM_MODEL=Qwen3.5-35B-A3B-UD-Q4_K_XL
LLM_API_KEY=hai-local-not-needed

# Frontend API URL (for UI)
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3440
